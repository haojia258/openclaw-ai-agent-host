# OpenClaw AI Agent Host - Environment Configuration
# Copy to .env and fill in values

# Server
PORT=3002
HOST=0.0.0.0

# Gateway connection (required)
GATEWAY_URL=http://localhost:3001
GATEWAY_TOKEN=oc_gateway_prod_v1_your_token_here

# Retry
MAX_RETRIES=3
RETRY_DELAY_MS=1000

# Audit
AUDIT_LOG_PATH=./logs/host-audit.log

# Execution mode (plan-only forever, do not change)
EXECUTION_MODE=plan-only
